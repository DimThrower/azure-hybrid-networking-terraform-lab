# -----------------------------
# Terraform local working files
# -----------------------------
**/.terraform/*
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform plan files
*.tfplan
tfplan
tfplan.*

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config files
.terraformrc
terraform.rc

# -----------------------------
# Terraform variable files
# -----------------------------
# Real tfvars may contain secrets or environment-specific values
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# But allow safe examples to be committed
!*.tfvars.example
!terraform.tfvars.example

# -----------------------------
# Azure / identity / secrets
# -----------------------------
*.pem
*.key
*.pfx
*.cer
*.crt
*.pub
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Local environment files
.env
.env.*
*.env

# -----------------------------
# Editor and OS files
# -----------------------------
.DS_Store
Thumbs.db

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/

# -----------------------------
# Logs
# -----------------------------
*.log

# -----------------------------
# Generated files / temporary files
# -----------------------------
tmp/
temp/
*.tmp
*.bak